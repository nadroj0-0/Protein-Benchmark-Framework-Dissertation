{
  "schema_version": 1,
  "name": "temporal-cafa-style",
  "benchmark_contract": {
    "id_overlap": "global-evaluation-disjoint",
    "sequence_overlap": "per-ontology-disjoint",
    "protein_id_pattern": "^[^\\s/\\\\]+$",
    "sequence_pattern": "^[A-Za-z*.-]+$",
    "allow_all_zero_rows": false,
    "allow_duplicate_rows": false,
    "allow_legacy_singular_protein_header": false,
    "require_benchmark_evidence": false
  },
  "modalities": {
    "sequence": {"directory": "prott5", "dimension": 1024},
    "text": {"directory": "exp_text_embeddings_temporal", "dimension": 768},
    "structure": {"directory": "IF1", "dimension": 512},
    "ppi": {"directory": "ppi", "dimension": 512}
  },
  "training": {
    "seq_model": "prott5",
    "fusion_type": "gated_bilinear",
    "use_late_fusion": true,
    "late_output_mode": "hybrid",
    "hidden_dim": 512,
    "dropout": 0.4,
    "modality_dropout": 0.1,
    "aux_loss_weight": 0.8
  },
  "evaluation": {
    "require_precomputed_ia": false
  }
}
